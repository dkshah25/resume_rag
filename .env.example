# ==============================================================================
# HireLens AI - Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials before running.
# ==============================================================================

# --- Google Gemini Configuration ---
# Your Gemini API Key from Google AI Studio (starts with 'AIzaSy' or client credentials).
# Used for primary parsing, embeddings (models/gemini-embedding-001) and grounded Q&A.
GEMINI_API_KEY=

# Optional alias for standard langchain-google-genai compatibility.
GOOGLE_API_KEY=

# --- Groq Configuration (High-Speed Fallback) ---
# Your Groq API Key from Groq Console (starts with 'gsk_').
# Used for sub-second, daily-quota-safe resume parameters extraction and chat responses.
GROQ_API_KEY=

# --- Backend Server Configuration ---
# Host binding address for the FastAPI backend (127.0.0.1 for local, 0.0.0.0 for containers/prod).
HOST=127.0.0.1

# Port number for the FastAPI backend server.
PORT=8000
